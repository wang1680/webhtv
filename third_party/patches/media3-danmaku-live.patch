+import org.robolectric.shadows.ShadowLooper;
+import org.robolectric.shadows.ShadowSystemClock;
+
+@RunWith(AndroidJUnit4.class)
+@Config(sdk = 28)
+public final class DanmakuViewLiveLoadTest {
+
+  private static final int TARGET_RATE_PER_SECOND = 300;
+  private static final int DELIVERY_WINDOWS_PER_SECOND = 20;
+  private static final int MESSAGES_PER_WINDOW = TARGET_RATE_PER_SECOND / DELIVERY_WINDOWS_PER_SECOND;
+  private static final int LIVE_PENDING_CAPACITY = 144;
+  private static final int MAX_ACTIVATION_ATTEMPTS_PER_FRAME = 16;
+
+  private DanmakuView view;
+  private Canvas canvas;
+  private ActivityController<Activity> activityController;
+
+  @Before
+  public void setUp() {
+    activityController = Robolectric.buildActivity(Activity.class).setup();
+    Context context = activityController.get();
+    view = new DanmakuView(context);
+    view.setConfig(
+        DanmakuConfig.DEFAULT.buildUpon()
+            .setMaxOnScreen(1000)
+            .setAllowOverlapping(true)
+            .build());
+    view.setDrawEnabled(false);
+    activityController.get().setContentView(view);
+    view.layout(0, 0, 1920, 1080);
+    view.start(0L);
+    canvas = new Canvas();
+  }
+
+  @After
+  public void tearDown() {
+    view.release();
+    activityController.close();
+  }
+
+  @Test
+  public void sustainedThreeHundredPerSecond_drainsWithoutOverflow() throws Exception {
+    int offered = 0;
+    for (int window = 0; window < DELIVERY_WINDOWS_PER_SECOND; window++) {
+      view.offerLiveBatch(createBatch(MESSAGES_PER_WINDOW, offered, 0L));
+      offered += MESSAGES_PER_WINDOW;
+      int expectedOffered = offered;
+      waitUntil(() -> view.getLiveStats().offered == expectedOffered);
+
+      view.onDraw(canvas);
+      DanmakuView.LiveStats stats = view.getLiveStats();
+      assertThat(stats.pending).isEqualTo(0);
+      assertThat(stats.droppedOverflow).isEqualTo(0L);
+      ShadowSystemClock.advanceBy(Duration.ofMillis(50));
+    }
+
+    DanmakuView.LiveStats stats = view.getLiveStats();
+    assertThat(stats.offered).isEqualTo(TARGET_RATE_PER_SECOND);
+    assertThat(stats.admitted).isEqualTo(TARGET_RATE_PER_SECOND);
+    assertThat(stats.highWaterMark).isEqualTo(MESSAGES_PER_WINDOW);
+    assertThat(stats.droppedExpired).isEqualTo(0L);
+    assertThat(MESSAGES_PER_WINDOW).isLessThan(MAX_ACTIVATION_ATTEMPTS_PER_FRAME);
+  }
+
+  @Test
+  public void burstAboveCapacity_dropsOldestAndBoundsOneFrameWork() throws Exception {
+    view.offerLiveBatch(createBatch(300, 0, 0L));
+    waitUntil(() -> view.getLiveStats().offered == 300L);
+
+    DanmakuView.LiveStats beforeDraw = view.getLiveStats();
+    assertThat(beforeDraw.pending).isEqualTo(LIVE_PENDING_CAPACITY);
+    assertThat(beforeDraw.highWaterMark).isEqualTo(LIVE_PENDING_CAPACITY);
+    assertThat(beforeDraw.droppedOverflow).isEqualTo(300L - LIVE_PENDING_CAPACITY);
+
+    view.onDraw(canvas);
+
+    DanmakuView.LiveStats afterDraw = view.getLiveStats();
+    assertThat(afterDraw.admitted).isEqualTo(MAX_ACTIVATION_ATTEMPTS_PER_FRAME);
+    assertThat(afterDraw.pending)
+        .isEqualTo(LIVE_PENDING_CAPACITY - MAX_ACTIVATION_ATTEMPTS_PER_FRAME);
+  }
+
+  @Test
+  public void expiredAndClearedItems_neverReachActiveRenderer() throws Exception {
+    long expiryMs = SystemClock.elapsedRealtime() + 10L;
+    view.offerLiveBatch(createBatch(1, 0, expiryMs));
+    waitUntil(() -> view.getLiveStats().pending == 1);
+    ShadowSystemClock.advanceBy(Duration.ofMillis(11));
+
+    view.onDraw(canvas);
+
+    DanmakuView.LiveStats expiredStats = view.getLiveStats();
+    assertThat(expiredStats.admitted).isEqualTo(0L);
+    assertThat(expiredStats.droppedExpired).isEqualTo(1L);
+    assertThat(expiredStats.pending).isEqualTo(0);
+
+    view.offerLiveBatch(createBatch(300, 1, 0L));
+    view.clearLiveItems();
+    drainAsyncWork();
+
+    DanmakuView.LiveStats clearedStats = view.getLiveStats();
+    assertThat(clearedStats.offered).isEqualTo(0L);
+    assertThat(clearedStats.pending).isEqualTo(0);
+    assertThat(clearedStats.active).isEqualTo(0);
+  }
+
+  private static List<Danmaku> createBatch(int count, int offset, long expiryMs) {
+    List<Danmaku> items = new ArrayList<>(count);
+    for (int i = 0; i < count; i++) {
+      Danmaku danmaku = new Danmaku("live-load-" + (offset + i), 0L);
+      if (expiryMs > 0L) {
+        danmaku.setLiveExpiryElapsedRealtimeMs(expiryMs);
+      }
+      items.add(danmaku);
+    }
+    return items;
+  }
+
+  private void waitUntil(BooleanSupplier condition) throws Exception {
+    long deadlineMs = System.nanoTime() / 1_000_000L + 5_000L;
+    while (!condition.getAsBoolean() && System.nanoTime() / 1_000_000L < deadlineMs) {
+      drainAsyncWork();
+    }
+    drainAsyncWork();
+    assertThat(condition.getAsBoolean()).isTrue();
+  }
+
+  private void drainAsyncWork() throws Exception {
+    Field field = DanmakuView.class.getDeclaredField("backgroundThread");
+    field.setAccessible(true);
+    HandlerThread thread = (HandlerThread) field.get(view);
+    if (thread != null) {
+      Shadows.shadowOf(thread.getLooper()).idle();
+    }
+    ShadowLooper.idleMainLooper();
+  }
+}
