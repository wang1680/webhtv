<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:left="1dp"
        android:right="1dp"
        android:top="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="8dp" />
            <solid android:color="#6B6F9F" />
        </shape>
    </item>

    <item android:bottom="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="8dp" />
            <solid android:color="#E6E6EA" />
            <stroke
                android:width="2dp"
                android:color="#F2FFFFFF" />
            <padding
                android:bottom="8dp"
                android:left="14dp"
                android:right="14dp"
                android:top="8dp" />
        </shape>
    </item>
</layer-list>
