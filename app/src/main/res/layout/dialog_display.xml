<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/shape_display_dialog_panel"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingTop="18dp"
    android:paddingEnd="14dp"
    android:paddingBottom="14dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:text="@string/control_display"
        android:textColor="#F2FFFFFF"
        android:textSize="18sp" />

    <com.google.android.flexbox.FlexboxLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:alignItems="center"
        app:flexWrap="wrap">

        <TextView
            android:id="@+id/display_time"
            style="@style/DisplayControl"
            android:text="@string/display_time" />

        <TextView
            android:id="@+id/display_traffic"
            style="@style/DisplayControl"
            android:text="@string/display_traffic" />

        <TextView
            android:id="@+id/display_size"
            style="@style/DisplayControl"
            android:text="@string/display_size" />

        <TextView
            android:id="@+id/display_progress"
            style="@style/DisplayControl"
            android:text="@string/display_progress" />

        <TextView
            android:id="@+id/display_mini"
            style="@style/DisplayControl"
            android:text="@string/display_mini" />

        <TextView
            android:id="@+id/display_title"
            style="@style/DisplayControl"
            android:text="@string/display_title" />

        <TextView
            android:id="@+id/display_params"
            style="@style/DisplayControl"
            android:text="@string/play_params"
            android:visibility="gone" />

    </com.google.android.flexbox.FlexboxLayout>
</LinearLayout>
